{
  "name": "skia-rs-wasm",
  "version": "0.1.0",
  "description": "TypeScript wrapper for Skia WASM renderer - provides canvas-like API for rendering Penpot nodes",
  "type": "module",
  "main": "./dist/renderer.cjs",
  "module": "./dist/renderer.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/renderer.es.js",
      "require": "./dist/renderer.cjs"
    },
    "./common": {
      "types": "./src/lib/common/index.ts",
      "import": "./src/lib/common/index.ts",
      "require": "./src/lib/common/index.ts",
      "default": "./src/lib/common/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "penpot-exporter": "^0.20.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.lib.json",
    "build:lib": "vite build && tsc -p tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rxjs": "^7.8.2",
    "zustand": "^5.0.10"
  },
  "pnpm": {
    "overrides": {
      "penpot-exporter": "workspace:*"
    }
  },
  "devDependencies": {
    "penpot-exporter": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@penpot/plugin-types": "^1.4.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
