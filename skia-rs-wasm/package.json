{
  "name": "skia-rs-wasm",
  "version": "0.1.0",
  "description": "TypeScript wrapper for Skia WASM renderer - provides canvas-like API for rendering Penpot nodes",
  "type": "module",
  "main": "./dist/renderer.cjs",
  "module": "./dist/renderer.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/renderer.es.js",
      "require": "./dist/renderer.cjs"
    },
    "./styles.css": "./dist/skia-rs-wasm.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "penpot-exporter": "^0.20.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:worker",
    "build:lib": "vite build",
    "build:worker": "vite build --config vite.worker.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "radix-ui": "^1.4.3",
    "rxjs": "^7.8.2",
    "shadcn": "^4.1.0",
    "svg-path-parser": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "pnpm": {
    "overrides": {
      "penpot-exporter": "workspace:*"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@penpot/plugin-types": "^1.4.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/svg-path-parser": "^1.1.6",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "penpot-exporter": "workspace:*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "3.2.4",
    "zustand": "^5.0.10"
  }
}
