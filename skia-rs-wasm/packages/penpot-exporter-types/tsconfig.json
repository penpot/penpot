{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ui/types": ["../penpot-exporter-figma-plugin/ui-src/types"],
      "@ui/types/*": ["../penpot-exporter-figma-plugin/ui-src/types/*"],
      "@plugin/*": ["../penpot-exporter-figma-plugin/plugin-src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/index.ts"]
}
