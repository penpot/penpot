  },
  "type": "module",
  "dependencies": {
    "archiver": "^7.0.1",
    "cookies": "^0.9.1",
    "date-fns": "^4.1.0",
    "generic-pool": "^3.9.0",
    "inflation": "^2.1.0",
    "ioredis": "^5.8.2",
    "playwright": "^1.57.0",
    "raw-body": "^3.0.2",
