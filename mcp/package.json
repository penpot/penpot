{
  "name": "penpot-mcp",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "install:all": "pnpm -r install",
    "build:all": "pnpm -r run build",
    "build:all:multi-user": "pnpm -r run build:multi-user",
    "start:all": "pnpm -r --parallel run start",
    "start:all:multi-user": "pnpm -r --parallel run start:multi-user",
    "bootstrap": "npm run install:all && npm run build:all",
    "bootstrap:multi-user": "npm run install:all && npm run build:all:multi-user",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/penpot/penpot.git"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.0.0"
  }
}
