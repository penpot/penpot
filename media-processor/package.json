{
  "name": "media-processor",
  "version": "1.0.0",
  "description": "Stateless HTTP service for Penpot image and font processing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "start": "node dist/index.js",
    "start:dev": "tsx --env-file=../backend/scripts/_env src/index.ts",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "fmt": "prettier --write src/ test/",
    "fmt:check": "prettier --check src/ test/",
    "clean": "rm -rf dist/"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "p-queue": "^9.3.2",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "prettier": "^3.6.2",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
